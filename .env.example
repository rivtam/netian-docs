# Docs Portal Configuration

# Environment
NODE_ENV=production

# Ports
AUTH_PORT=4000
DOCS_PORT=3000

# Database (uses infrastructure PostgreSQL)
DB_PASSWORD=changeme_in_production

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_make_it_long_and_random

# Superuser Account (initial admin)
SUPERUSER_EMAIL=admin@docs.local
SUPERUSER_PASSWORD=changeme123
SUPERUSER_NAME=Super Admin

# URLs
DOCS_URL=http://localhost:3000
AUTH_URL=http://localhost:4000

# For production, use actual domain:
# DOCS_URL=https://docs.yourdomain.com
# AUTH_URL=https://docs.yourdomain.com/auth
